PORT=3000
NODE_ENV=production

# Optional admin guard for hidden storyteller-side AI settings.
# Leave empty for loopback-only local editing. Set a strong server-side token before exposing remotely.
BOTC_AI_SETTINGS_ADMIN_TOKEN=

# Optional admin guard for cloud game review records.
# Set this before exposing review records on a public server.
BOTC_GAME_RECORDS_ADMIN_TOKEN=
# Set to 1 only if deployed game review records are intended to be public.
BOTC_GAME_RECORDS_PUBLIC=0

# Optional local JSON room snapshots for restart recovery.
# Defaults to .botc-room-snapshots when unset; keep this directory out of Git.
BOTC_ROOM_SNAPSHOT_DIR=.botc-room-snapshots

# Optional parser enhancement from the replay-knowledge role-token alias registry.
# Default off. Set to 1 only after running verify:role-token-alias-production-parser.
BOTC_ENABLE_ROLE_TOKEN_ALIAS_RESOLVER=0

# Optional backend-only AI assistance.
# Leave disabled for pure local rules. Never expose these values in frontend code.
BOTC_AI_PROVIDER=disabled
# BOTC_AI_PROVIDER=openai-compatible
# BOTC_AI_API_KEY=
# BOTC_AI_MODEL=
# BOTC_AI_BASE_URL=https://api.openai.com/v1
# BOTC_AI_TIMEOUT_MS=12000
# BOTC_AI_MAX_TOKENS=220
# BOTC_AI_TEMPERATURE=0.2
# MiniMax-M3/OpenAI-compatible tuning. Leave blank for generic providers.
# BOTC_AI_THINKING=disabled
# BOTC_AI_REASONING_SPLIT=true
# BOTC_AI_USE_MAX_COMPLETION_TOKENS=true
